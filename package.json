{
  "name": "tectex",
  "version": "1.1.0",
  "private": true,
  "description": "Local-first LaTeX resume editor",
  "scripts": {
    "build": "esbuild local_app/app.js --bundle --outfile=local_app/bundle.js --format=iife --target=es2020 --minify",
    "watch": "esbuild local_app/app.js --bundle --outfile=local_app/bundle.js --format=iife --target=es2020 --watch"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "codemirror": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/language": "^6.10.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.35.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/autocomplete": "^6.18.0",
    "@lezer/highlight": "^1.2.0",
    "@lezer/lr": "^1.4.0"
  }
}
